---
import Head from "@components/_head.astro"
import Scripts from "@components/_scripts.astro"

const title = "Global Banking Empowerment 4 | Lockscreen"
const path = "../../../dist"
const htmlPath = ".."
const year = new Date().getFullYear();

// Smart path resolution: calculate relative path based on directory depth
const pathname = Astro.url.pathname;
const pathSegments = pathname.split('/').filter(segment => segment !== '');
const depth = pathSegments.length > 0 ? pathSegments.length - 1 : 0;
const deploymentPath = depth === 0 ? './' : '../'.repeat(depth);
---

<!DOCTYPE html>
<html lang="en">
  <!--begin::Head-->
  <head>
    <Head title={title} path={path} />
  </head>
  <!--end::Head-->
  <!--begin::Body-->
  <body class="lockscreen bg-body-secondary">
    <main class="lockscreen-wrapper">
      <h1 class="lockscreen-logo">
        <a href={htmlPath + "/index2.html"}><b>Admin</b>LTE</a>
      </h1>

      <div class="lockscreen-name">John Doe</div>

      <div class="lockscreen-item">
        <div class="lockscreen-image">
          <img src={deploymentPath + "assets/img/user1-128x128.jpg"} alt="John Doe" />
        </div>

        <form class="lockscreen-credentials">
          <label class="visually-hidden" for="lockscreenPassword">Password</label>
          <div class="input-group">
            <input
              id="lockscreenPassword"
              type="password"
              class="form-control shadow-none"
              placeholder="password"
            />
            <div class="input-group-text border-0 bg-transparent px-1">
              <button type="button" class="btn shadow-none" aria-label="Sign in">
                <i class="bi bi-box-arrow-right text-body-secondary"></i>
              </button>
            </div>
          </div>
        </form>
      </div>

      <div class="help-block text-center">
        Enter your password to retrieve your session
      </div>
      <div class="text-center">
        <a href="login.html" class="text-decoration-none">Or sign in as a different user</a>
      </div>
      <div class="lockscreen-footer text-center">
        Copyright © 2014-{year} &nbsp;
        <b><a href="https://c-globalbankingempowerment.online" class="link-primary link-offset-2 link-underline-opacity-25 link-underline-opacity-100-hover">c-globalbankingempowerment.online</a></b> <br />
        All rights reserved
      </div>
    </main>

    <Scripts />
  </body><!--end::Body-->
</html>

